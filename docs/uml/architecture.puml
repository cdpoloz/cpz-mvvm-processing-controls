@startuml
title High-Level Architecture
skinparam packageStyle rectangle
skinparam shadowing false

package "Theme" {
  interface ThemeProvider
  class ThemeManager
  class Theme
  class ThemeSnapshot
  class ThemeTokens
}

package "MVVM Pipeline" {
  class View
  class ViewState
  class Style
  class RenderStyle
  class Renderer
}

ThemeManager ..|> ThemeProvider
ThemeManager --> Theme
ThemeManager --> ThemeSnapshot : rebuilds on setTheme()
ThemeSnapshot --> ThemeTokens
View --> ThemeProvider : reads cached snapshot
View --> ViewState : builds
View --> ThemeSnapshot : passes to style
Style --> ViewState
Style --> ThemeSnapshot
Style --> RenderStyle
Renderer --> RenderStyle
@enduml
