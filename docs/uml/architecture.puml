@startuml
title High-Level Architecture
skinparam packageStyle rectangle
skinparam shadowing false

package "MVVM" {
  class Model
  class ViewModel
  class View
  class ViewState
}

package "Rendering" {
  class Style
  class RenderStyle
  class Renderer
}

package "Infrastructure" {
  interface ThemeProvider
  class ThemeManager
  class ThemeSnapshot
  class InputManager
  interface InputLayer
  class FocusManager
  class OverlayManager
}

ThemeManager ..|> ThemeProvider
ThemeProvider --> ThemeSnapshot

ViewModel --> Model : updates
View --> ViewModel : reads
View --> ViewState : builds
View --> ThemeProvider : reads snapshot
Style --> ViewState : resolves
Style --> ThemeSnapshot : consumes
Style --> RenderStyle : creates
Renderer --> RenderStyle : draws

InputManager --> InputLayer : dispatches
InputLayer --> ViewModel : forwards input
FocusManager --> ViewModel : manages focus
OverlayManager --> View : coordinates overlays
@enduml
