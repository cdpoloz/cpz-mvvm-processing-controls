@startuml
title High-Level Architecture
skinparam packageStyle rectangle
skinparam shadowing false

package "External Boundary" {
  class ExternalSource
  class ExternalAdapter
}

package "Input" {
  class PointerEvent {
    +type : MOVE|PRESS|RELEASE|DRAG|WHEEL
    +x : float
    +y : float
    +pressed : boolean
    +button : int
    +shift : boolean
    +ctrl : boolean
    +alt : boolean
    +wheelDelta : float
  }
  class KeyboardEvent {
    +type : PRESS|TYPE|RELEASE
    +key : char
    +keyCode : int
    +shift : boolean
    +ctrl : boolean
    +alt : boolean
  }
  class KeyboardState
  class InputManager
  interface InputLayer
  class InputAdapter
  class FocusManager
}

package "MVVM" {
  class Model
  class ViewModel
  class View
  class ViewState
}

package "Public Facades" {
  interface Control
  class ConcreteControlFacade
}

package "JSON Configuration" {
  class JsonDocument
  class ControlConfigLoader
  class ControlFactoryRegistry
}

package "Rendering" {
  class Style
  class RenderStyle
  class Renderer
}

package "Infrastructure" {
  interface ThemeProvider
  class ThemeManager
  class ThemeSnapshot
  class OverlayManager
}

ThemeManager ..|> ThemeProvider
ThemeProvider --> ThemeSnapshot

ExternalSource --> ExternalAdapter : raw callbacks or state
ExternalAdapter --> PointerEvent : creates
ExternalAdapter --> KeyboardEvent : creates
ExternalAdapter --> KeyboardState : updates when needed
ExternalAdapter --> InputManager : dispatches events
JsonDocument --> ControlConfigLoader : loads
ControlConfigLoader --> ControlFactoryRegistry : dispatches by type
ControlFactoryRegistry --> ConcreteControlFacade : creates
InputManager --> InputLayer : dispatches
InputLayer --> InputAdapter : forwards
InputAdapter --> ViewModel : updates interaction
FocusManager --> ViewModel : manages focus

ConcreteControlFacade ..|> Control
ConcreteControlFacade --> ViewModel : delegates through closed facade
ViewModel --> Model : updates
View --> ViewModel : reads
View --> ViewState : builds
View --> ThemeProvider : reads snapshot
Style --> ViewState : resolves
Style --> ThemeSnapshot : consumes
Style --> RenderStyle : creates
Renderer --> RenderStyle : draws
OverlayManager --> View : coordinates overlays
@enduml
