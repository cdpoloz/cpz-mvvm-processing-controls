@startuml
title DropDown Control Structure
skinparam packageStyle rectangle
skinparam shadowing false

class PointerEvent
class InputLayer
class DropDownOverlayController
class DropDownViewModel
class DropDownView
class DropDownViewState
class DefaultDropDownStyle
class DropDownRenderStyle
class DefaultDropDownRenderer
class ThemeSnapshot

PointerEvent --> InputLayer : dispatched
InputLayer --> DropDownOverlayController : overlay capture
DropDownOverlayController --> DropDownView : forwards pointer state
DropDownOverlayController --> DropDownViewModel : updates expansion / selection
DropDownView --> DropDownViewState
DropDownView --> ThemeSnapshot
DefaultDropDownStyle --> DropDownViewState
DefaultDropDownStyle --> ThemeSnapshot
DefaultDropDownStyle --> DropDownRenderStyle
DefaultDropDownRenderer --> DropDownRenderStyle
@enduml
