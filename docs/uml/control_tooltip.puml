@startuml
title Tooltip Overlay Structure
skinparam packageStyle rectangle
skinparam shadowing false

class TooltipOverlayController
class TooltipModel
class TooltipViewModel
class TooltipView
class TooltipViewState
class DefaultTooltipStyle
class TooltipRenderStyle
class DefaultTooltipRenderer
class OverlayManager
interface ThemeProvider
class ThemeSnapshot

TooltipOverlayController --> TooltipModel : owns
TooltipOverlayController --> TooltipViewModel : owns
TooltipOverlayController --> TooltipView : owns
TooltipOverlayController --> OverlayManager : registers overlay
TooltipViewModel --> TooltipModel : reads / updates
TooltipView --> TooltipViewModel : reads
TooltipView --> TooltipViewState : builds
TooltipView --> DefaultTooltipStyle : renders with
DefaultTooltipStyle --> ThemeProvider : reads snapshot
ThemeProvider --> ThemeSnapshot
DefaultTooltipStyle --> TooltipViewState : resolves
DefaultTooltipStyle --> TooltipRenderStyle : creates
DefaultTooltipRenderer --> TooltipRenderStyle : draws
@enduml
