@startuml
title Core Infrastructure
skinparam packageStyle rectangle
skinparam shadowing false

package "Input" {
  class InputManager
  interface InputLayer
  class FocusManager
  class OverlayManager
}

package "Theme" {
  interface ThemeProvider
  class ThemeManager
  class Theme
  class ThemeSnapshot
  class ThemeTokens
}

ThemeManager ..|> ThemeProvider
ThemeProvider --> ThemeSnapshot
ThemeManager --> ThemeSnapshot : caches
ThemeSnapshot --> ThemeTokens
@enduml
