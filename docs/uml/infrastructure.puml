@startuml
title Core Infrastructure
skinparam packageStyle rectangle
skinparam shadowing false

package "Input" {
  class ProcessingKeyboardAdapter
  class KeyboardState
  class InputManager
  interface InputLayer
  interface PointerInputTarget
  interface KeyboardInputTarget
  class FocusManager
}

package "Theme" {
  interface ThemeProvider
  class ThemeManager
  class ThemeSnapshot
  class ThemeTokens
}

package "Overlay" {
  class OverlayManager
}

package "Binding" {
  class Binding
  interface ValueListener<T>
}

ThemeManager ..|> ThemeProvider
ThemeProvider --> ThemeSnapshot
ThemeSnapshot --> ThemeTokens

ProcessingKeyboardAdapter --> KeyboardState : updates
ProcessingKeyboardAdapter --> InputManager : dispatches keyboard
InputManager --> InputLayer : dispatches
InputLayer --> PointerInputTarget : pointer events
InputLayer --> KeyboardInputTarget : keyboard events
FocusManager --> KeyboardInputTarget : focuses

Binding --> ValueListener : registers
@enduml
