@startuml
title Core Infrastructure
skinparam packageStyle rectangle
skinparam shadowing false

package "External Boundary" {
  class ExternalSource
  class ExternalAdapter
  class ProcessingKeyboardAdapter
}

package "Input" {
  class PointerEvent {
    +type : MOVE|PRESS|RELEASE|DRAG|WHEEL
    +x : float
    +y : float
    +pressed : boolean
    +button : int
    +shift : boolean
    +ctrl : boolean
    +alt : boolean
    +wheelDelta : float
  }
  class KeyboardEvent {
    +type : PRESS|TYPE|RELEASE
    +key : char
    +keyCode : int
    +shift : boolean
    +ctrl : boolean
    +alt : boolean
  }
  class KeyboardState
  class InputManager
  interface InputLayer
  class InputAdapter
  interface PointerInputTarget
  interface KeyboardInputTarget
  class FocusManager
}

package "Theme" {
  interface ThemeProvider
  class ThemeManager
  class ThemeSnapshot
  class ThemeTokens
}

package "Overlay" {
  class OverlayManager
}

ThemeManager ..|> ThemeProvider
ThemeProvider --> ThemeSnapshot
ThemeSnapshot --> ThemeTokens

ExternalSource --> ExternalAdapter : raw callbacks or state
ExternalAdapter --> PointerEvent : creates
ExternalAdapter --> KeyboardEvent : creates
ExternalAdapter --> KeyboardState : updates when needed
ExternalAdapter --> InputManager : dispatches
ProcessingKeyboardAdapter --|> ExternalAdapter

InputManager --> InputLayer : dispatches
InputLayer --> InputAdapter : forwards
InputAdapter --> PointerInputTarget : pointer events
InputAdapter --> KeyboardInputTarget : keyboard events
FocusManager --> KeyboardInputTarget : focuses
@enduml
